{
  "name": "instagram-professional-connect",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "node scripts/dev-with-tunnel.mjs",
    "dev:app": "next dev -p 3020",
    "build": "next build",
    "start": "next start -p 3020",
    "lint": "eslint .",
    "test:unit": "node --experimental-strip-types --experimental-specifier-resolution=node --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "postinstall": "dotenv -e .env.local -- prisma generate || prisma generate"
  },
  "dependencies": {
    "22": "^0.0.0",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^6.6.0",
    "@sparticuz/chromium": "^147.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^15.2.4",
    "node-cron": "^4.2.1",
    "openai": "^5.12.2",
    "pg": "^8.16.3",
    "puppeteer": "^24.7.2",
    "puppeteer-core": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
